# Django
DJANGO_SETTINGS_MODULE=tip_backend.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=tip_backend
POSTGRES_USER=tip_user
POSTGRES_PASSWORD=tip_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# External APIs (future use)
TRELLO_API_KEY=
TRELLO_API_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS (frontend dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend portal (use "true" only for demo mocks)
NEXT_PUBLIC_PORTAL_MOCKS=false
