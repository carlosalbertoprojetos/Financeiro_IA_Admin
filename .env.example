# Django
DJANGO_SETTINGS_MODULE=tip_backend.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=tip_backend
POSTGRES_USER=tip_user
POSTGRES_PASSWORD=tip_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# External APIs (future use)
TRELLO_API_KEY=
TRELLO_API_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS (frontend dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend portal (use "true" only for demo mocks)
NEXT_PUBLIC_PORTAL_MOCKS=false

# EOR Observability — include full decision trace in API responses
EOR_DEBUG_MODE=false

# EOR Evolution Control Plane — block HIGH risk changes without approval
EOR_SAFE_MODE=false

# EOR Decision Action Layer — auto execution disabled by default
DAL_AUTO_EXECUTION=false
DAL_MAX_AUTO_ACTIONS_PER_HOUR=10
DAL_ACTION_COOLDOWN_SECONDS=300

# EOR Business Value Engine — financial translation (all rates configurable)
BVE_HOURLY_RATE_BRL=150
BVE_BASE_IMPACT_BRL=20000
BVE_HOURS_PER_WORKDAY=8

# POCL — Pilot Operational Control Loop (human-in-the-loop operational pilot)
POCL_ENABLED=false
POCL_ACTIVE=false
POCL_BOARD_ID=
POCL_TEAM_NAME=Operations
